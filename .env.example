# 应用
APP_HOST=127.0.0.1
APP_PORT=8000
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
VITE_API_URL=http://localhost:8000/api

# 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=interview_echo

# LLM
LLM_API_KEY=
LLM_BASE_URL=https://yunwu.ai/v1
LLM_MODEL=gpt-4o
LLM_EMBEDDING_MODEL=text-embedding-3-small

# 兼容旧配置名（deprecated，可不填）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODEL=
EMBEDDING_MODEL=

# GitHub 深挖（可选）
GITHUB_TOKEN=

# 语音识别
WHISPER_MODEL=small

# 代码练习（Judge0）
# 先运行 scripts\start_judge0.ps1，后端只访问 localhost。
JUDGE0_BASE_URL=http://127.0.0.1:2358
JUDGE0_TIMEOUT_SECONDS=12
JUDGE0_POLL_INTERVAL_SECONDS=0.6
JUDGE0_MAX_POLL_ATTEMPTS=90
CODE_MAX_SOURCE_LENGTH=20000
CODE_MAX_TEST_CASES=30
CODE_MAX_CONCURRENT_JUDGE_CASES=8
CODE_OUTPUT_LIMIT=4000
