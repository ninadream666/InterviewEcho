# 服务器配置
APP_HOST=127.0.0.1
APP_PORT=8000

# MySQL数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_PASSWORD=
DB_NAME=interview_echo

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=knowledge_base

# LLM（DeepSeek）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 语音识别（Whisper）
WHISPER_MODEL=base

# 代码练习（Docker Judge0）
# 先运行 scripts\start_judge0.ps1，后端只访问 localhost。
JUDGE0_BASE_URL=http://127.0.0.1:2358
JUDGE0_TIMEOUT_SECONDS=12
JUDGE0_POLL_INTERVAL_SECONDS=0.6
JUDGE0_MAX_POLL_ATTEMPTS=90
CODE_MAX_SOURCE_LENGTH=20000
CODE_MAX_TEST_CASES=30
CODE_MAX_CONCURRENT_JUDGE_CASES=8
CODE_OUTPUT_LIMIT=4000
